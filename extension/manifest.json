{
  "manifest_version": 3,
  "name": "Mineradio Connector",
  "version": "0.4.5",
  "description": "Connects Mineradio Web to browser music sessions for local testing.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://music.163.com/*",
    "http://music.163.com/*",
    "https://*.music.126.net/*",
    "http://*.music.126.net/*",
    "https://www.kugou.com/*",
    "https://m.kugou.com/*",
    "https://m3ws.kugou.com/*",
    "https://wwwapi.kugou.com/*",
    "https://complexsearch.kugou.com/*",
    "https://fxsong.kugou.com/*",
    "https://webfs.kugou.com/*",
    "https://*.kugou.com/*",
    "https://mrchenyh.github.io/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://qq.com/*",
    "https://*.qq.com/*",
    "https://y.qq.com/*",
    "https://u.y.qq.com/*",
    "https://c.y.qq.com/*",
    "https://i.y.qq.com/*",
    "https://q1.qlogo.cn/*",
    "https://*.qpic.cn/*",
    "https://*.gtimg.cn/*",
    "https://*.qqmusic.qq.com/*",
    "https://*.qqmusic.tc.qq.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mrchenyh.github.io/Mineradio-Web/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Mineradio Connector",
    "default_popup": "popup.html"
  }
}
